    "gsap": "^3.14.2",
    "lenis": "^1.3.18",
    "lucide-react": "^1.8.0",
    "matter-js": "^0.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.1",
