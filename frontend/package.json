{
  "name": "moment-maker-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently \"vite\" \"npm run build:watch --workspaces --if-present\"",
    "build": "vite build",
    "build:templates": "npm run build --workspaces --if-present",
