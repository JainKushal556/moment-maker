# Handle line endings automatically for files detected as text 
# and perform LF normalization (convert CRLF to LF on commit)
* text=auto

# Explicitly declare text files you want to always be LF or CRLF
*.js text eol=lf
*.jsx text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
